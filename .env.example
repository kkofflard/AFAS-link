# ============================================================
# AFAS-link omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in
# ============================================================

# Database
DATABASE_URL=sqlite:///./afas_link.db

# Configuratiebestand pad
CONFIG_PATH=config/config.yaml

# Demo modus (geen echte API's nodig)
DEMO_MODE=true

# ---- AFAS omgevingen ----
# Token data (alleen het <data>-deel, zonder XML-wrapper)
AFAS_ENV1_TOKEN=UW_AFAS_TOKEN_HIER
AFAS_ENV2_TOKEN=

# ---- Microsoft Entra ID (Azure AD) ----
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ---- Active Directory ----
AD_BIND_PASSWORD=

# ---- Applicatie ----
APP_SECRET_KEY=verander-dit-naar-een-veilige-sleutel
LOG_LEVEL=INFO
